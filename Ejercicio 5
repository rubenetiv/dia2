import math

# Suma de dos números
def add_two_numbers(a, b):
    """Devuelve la suma de dos números"""
    return a + b

#  Área de un círculo
def area_del_circulo(radio):
    """Calcula el área de un círculo"""
    return math.pi * radio ** 2

# Suma de números arbitrarios con validación
def add_all_nums(*args):
    """
    Suma todos los números pasados como argumentos.
    Si algún elemento no es numérico, devuelve un mensaje de error.
    """
    total = 0
    for num in args:
        if not isinstance(num, (int, float)):
            return "Error: Todos los elementos deben ser numéricos"
        total += num
    return total

# Convertir Celsius a Fahrenheit
def convert_celsius_to_fahrenheit(celsius):
    """Convierte grados Celsius a Fahrenheit"""
    return (celsius * 9/5) + 32

# Solución de ecuación cuadrática
def solve_quadratic_eqn(a, b, c):
    """
    Calcula las soluciones de la ecuación ax² + bx + c = 0
    Devuelve una tupla con las soluciones o un mensaje si no hay soluciones reales.
    """
    discriminante = b**2 - 4*a*c
    if discriminante < 0:
        return "No tiene soluciones reales"
    elif discriminante == 0:
        x = -b / (2*a)
        return (x,)
    else:
        x1 = (-b + math.sqrt(discriminante)) / (2*a)
        x2 = (-b - math.sqrt(discriminante)) / (2*a)
        return (x1, x2)

#  Imprimir lista elemento por elemento
def print_list(lista):
    """Imprime cada elemento de la lista"""
    for elemento in lista:
        print(elemento)

# Devolver lista inversa usando bucles
def lista_inversa(lista):
    """Devuelve la lista invertida"""
    inversa = []
    for i in range(len(lista)-1, -1, -1):
        inversa.append(lista[i])
    return inversa

# =========================
# Ejemplos de uso
# =========================

print("Suma 2 números:", add_two_numbers(5, 10))
print("Área del círculo (radio 5):", area_del_circulo(5))
print("Suma de varios números:", add_all_nums(1, 2, 3))
print("Conversión 25°C a F:", convert_celsius_to_fahrenheit(25))
print("Soluciones ecuación 1x² -3x +2 =", solve_quadratic_eqn(1, -3, 2))
print("Lista original:", [1, 2, 3, 4])
print("Lista inversa:", lista_inversa([1, 2, 3, 4]))
print("Imprimir lista:")
print_list(["Python", "Java", "C++"])
