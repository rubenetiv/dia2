# a) Diccionario vacío
perro = {}

# b) Agregar datos
perro["nombre"] = "Max"
perro["color"] = "café"
perro["raza"] = "Pug"
perro["patas"] = 4
perro["edad"] = 6

print("Diccionario perro:", perro)

# c) Diccionario estudiante
estudiante = {
    "nombre": "Ruben",
    "apellido": "Vite",
    "sexo": "M",
    "edad": 48,
    "estado_civil": "casado",
    "habilidades": ["Python", "SQL"],
    "pais": "México",
    "ciudad": "CDMX",
    "direccion": "Vicente Guerrero 17"
}

print("Diccionario estudiante:", estudiante)

# d) Longitud del diccionario
print("Longitud del estudiante:", len(estudiante))

# e) Valor de habilidades y tipo
habilidades = estudiante["habilidades"]
print("Habilidades:", habilidades)
print("Tipo:", type(habilidades))

# f) Agregar habilidades
estudiante["habilidades"].append("Java")
estudiante["habilidades"].append("C++")

print("Habilidades actualizadas:", estudiante["habilidades"])

# g) Claves como lista
claves = list(estudiante.keys())
print("Claves:", claves)

# h) Valores como lista
valores = list(estudiante.values())
print("Valores:", valores)

# i) Convertir a lista de tuplas
items = list(estudiante.items())
print("Items (tuplas):", items)

# j) Eliminar un elemento
estudiante.pop("direccion")
print("Después de eliminar dirección:", estudiante)

# k) Eliminar un diccionario
del perro
print("Diccionario 'perro' eliminado")
